{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "listenPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "managementPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "forwarding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kubeDNS": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "clusterIP": {
              "type": "string"
            }
          }
        },
        "upstream": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "provider": {
              "type": "string",
              "enum": ["quad9", "cloudflare", "google"]
            }
          }
        },
        "zones": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "resolver": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rebindingProtection": {
          "type": "boolean"
        },
        "logBogus": {
          "type": "boolean"
        },
        "serveStale": {
          "type": "boolean"
        },
        "glueChecking": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "enum": ["normal", "strict", "permissive"] }
          ]
        },
        "dnssec": {
          "type": "boolean"
        },
        "dnssecNegativeTrustAnchors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workers": {
          "oneOf": [
            { "type": "string", "enum": ["auto", ""] },
            { "type": "integer", "minimum": 1 }
          ]
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["", "crit", "err", "warning", "notice", "info", "debug"]
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sizeLimit": {
          "type": "string",
          "pattern": "^[0-9]+(Mi|Gi|Ki|M|G|K)?$"
        },
        "ttlMin": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "ttlMax": {
          "oneOf": [
            { "type": "string" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "prefetchExpiring": {
          "type": "boolean"
        },
        "prefetchPrediction": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "object" }
          ]
        }
      }
    },
    "configOverride": {
      "type": "object"
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "flavor": {
          "type": "string",
          "enum": ["cilium", "kubernetes"]
        },
        "ingressNamespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metricsNamespace": {
          "type": "string",
          "minLength": 1
        },
        "egressToInternet": {
          "type": "boolean"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
            "memory": { "oneOf": [{ "type": "string" }, { "type": "number" }] }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
            "memory": { "oneOf": [{ "type": "string" }, { "type": "number" }] }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "clusterIP": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "interval": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "namespaceSelector": {
              "type": "object"
            }
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "strategy": {
      "type": "object"
    },
    "extraVolumes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "defaultAntiAffinity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "topologyKey": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["preferred", "required"]
        }
      }
    },
    "affinity": {
      "type": "object"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        }
      }
    }
  }
}
